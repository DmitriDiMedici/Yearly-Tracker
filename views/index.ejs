<%- include("partials/header.ejs") %>

<main>
  <header>
    <div class="container top-header">
      <div class="title">
        <div class="icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-book-open-icon lucide-book-open"
          >
            <path d="M12 7v14" />
            <path
              d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"
            />
          </svg>
        </div>
        <div class="title-text">
          <h1>Book tracker</h1>
          <h2>Books read in <%= currentYear %></h2>
        </div>
      </div>
      <a href="#" class="add-button" id="open-modal-btn">
        <div class="button-content">
          <div class="button-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-plus-icon lucide-plus"
            >
              <path d="M5 12h14" />
              <path d="M12 5v14" />
            </svg>
          </div>
          <div class="button-text">Add new book</div>
        </div>
      </a>
    </div>
  </header>

  <div class="container content-title">
    <h2>
      <%= bookList.length %> book<%= bookList.length > 1 ? 's' : '' %> read in
      <%= currentYear %>
    </h2>
  </div>

  <div class="container book-grid">
    <% bookList.forEach((book) => { %>

    <div class="card">
      <div class="card-actions">
        <button class="menu-dots-btn">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="1" />
            <circle cx="12" cy="5" r="1" />
            <circle cx="12" cy="19" r="1" />
          </svg>
        </button>
        <div class="dropdown-menu">
          <button
            class="edit-btn"
            data-id="<%= book.id %>"
            data-title="<%= book.title %>"
            data-author="<%= book.author %>"
            data-cover="<%= book.cover_url %>"
            data-score="<%= book.score %>"
            data-comment="<%= book.comment %>"
          >
            Edit
          </button>
          <form action="/delete" method="POST" style="margin: 0">
            <input type="hidden" name="deleteItemId" value="<%= book.id %>" />
            <button class="delete-btn">Delete</button>
          </form>
        </div>
      </div>

      <div class="card-image">
        <img src="<%= book.cover_url %>" alt="Portada del libro" />
      </div>
      <div class="card-body">
        <h3 class="card-title"><%= book.title %></h3>
        <p class="author-name">By <%= book.author %></p>
        <div class="stars">
          <% for (let i = 1; i <= 5; i++) { %> <% if (book.score >= i ) { %>
          <i class="fa-solid fa-star"></i>
          <% } else if (book.score >= i - 0.5) { %>
          <i class="fa-solid fa-star-half-stroke"></i>
          <% } else { %>
          <i class="fa-regular fa-star"></i>
          <% } %> <% } %>
        </div>
        <p class="card-text"><%= book.comment %></p>
        <p class="card-date">
          <%= new Date(book.created_at).toLocaleDateString('en-EN', { day:
          '2-digit', month: 'long', year: 'numeric' }) %>
        </p>
      </div>
    </div>

    <% }) %>
  </div>

  <dialog id="add-book-modal" class="modal">
    <div class="modal-header">
      <h3 id="modal-title">Add New Book</h3>
      <button type="button" id="close-x-btn" class="close-x">&times;</button>
    </div>

    <form action="/add" method="POST" class="modal-form" id="book-modal-form">
      <div class="form-group">
        <input type="hidden" name="edit_id" id="edit-id-input" value="" />
        <label for="title">Book Title</label>
        <div class="input-with-btn">
          <input
            type="text"
            id="title"
            name="title"
            placeholder="Enter book title"
            required
          />
          <button
            type="button"
            class="search-api-btn"
            id="search-title-btn"
            title="Auto-fill from Open Library"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
          </button>
        </div>
      </div>
      <div class="form-group">
        <label for="author">Author</label>
        <div class="input-with-btn">
          <input
            type="text"
            id="author"
            name="author"
            placeholder="Enter author name"
            required
          />
          <button
            type="button"
            class="search-api-btn"
            id="search-author-btn"
            title="Auto-fill from Open Library"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
          </button>
        </div>
      </div>
      <div class="form-group">
        <label for="cover_url">Cover Image URL</label>
        <input
          type="url"
          id="cover_url"
          name="cover_url"
          placeholder="https://example.com/cover.jpg"
          required
        />
      </div>
      <div class="form-group">
        <label>Rating</label>
        <div class="rating-input" id="star-rating-container">
          <i class="fa-regular fa-star" data-value="1"></i>
          <i class="fa-regular fa-star" data-value="2"></i>
          <i class="fa-regular fa-star" data-value="3"></i>
          <i class="fa-regular fa-star" data-value="4"></i>
          <i class="fa-regular fa-star" data-value="5"></i>
        </div>
        <input type="hidden" name="score" id="score-input" value="0" required />
      </div>
      <div class="form-group">
        <label for="comment">Comment</label>
        <textarea
          name="comment"
          id="comment"
          rows="3"
          placeholder="Share your thoughts about this book..."
        ></textarea>
      </div>
      <div class="modal-actions">
        <button type="button" id="cancel-btn" class="btn-cancel">Cancel</button>
        <button type="submit" class="btn-submit" id="submit-btn">
          Add Review
        </button>
      </div>
    </form>
  </dialog>
</main>

<%- include("partials/footer.ejs") %>
